; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Peraviz"
run/main_scene="res://test.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/mode=2

[peraviz]

peraviz_debug_baseline=false

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering/lights_and_shadows/positional_shadow/atlas_size=1024
rendering/environment/volumetric_fog/volume_size=64
rendering/environment/volumetric_fog/volume_depth=64
rendering/environment/volumetric_fog/use_filter=true

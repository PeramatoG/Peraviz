{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-static-base",
      "hidden": true,
      "displayName": "Windows static vcpkg base",
      "description": "Build peraviz_native as a GDExtension DLL while statically linking third-party vcpkg dependencies.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "BUILD_SHARED_LIBS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-debug-static",
      "inherits": "windows-static-base",
      "displayName": "Windows Debug static vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release-static",
      "inherits": "windows-static-base",
      "displayName": "Windows Release static vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug-static",
      "configurePreset": "windows-debug-static",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-static",
      "configurePreset": "windows-release-static",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug-static",
      "configurePreset": "windows-debug-static",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-static",
      "configurePreset": "windows-release-static",
      "configuration": "Release"
    }
  ]
}

{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-static-base",
      "hidden": true,
      "displayName": "Windows static vcpkg base",
      "description": "Build peraviz_native as a GDExtension DLL while statically linking third-party vcpkg dependencies and using the dynamic MSVC runtime.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "toolchainFile": "C:/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
        "BUILD_SHARED_LIBS": "OFF",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-debug-static",
      "inherits": "windows-static-base",
      "displayName": "Windows Debug static vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-release-static",
      "inherits": "windows-static-base",
      "displayName": "Windows Release static vcpkg",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug-static",
      "configurePreset": "windows-debug-static",
      "configuration": "Debug",
      "jobs": 1
    },
    {
      "name": "windows-release-static",
      "configurePreset": "windows-release-static",
      "configuration": "Release",
      "jobs": 1
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug-static",
      "configurePreset": "windows-debug-static",
      "configuration": "Debug"
    },
    {
      "name": "windows-release-static",
      "configurePreset": "windows-release-static",
      "configuration": "Release"
    }
  ]
}